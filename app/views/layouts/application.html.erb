<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Scoreboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Scoreboard">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <nav class="bg-white shadow">
      <div class="container mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to "Scoreboard", root_path, class: "text-xl font-bold text-gray-800" %>
        <div>
          <% if user_signed_in? %>
            <span class="text-sm text-gray-600 mr-3"><%= current_user.display_name %></span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "text-sm text-red-600 hover:text-red-800" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="container mx-auto px-4 mt-4">
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="container mx-auto px-4 mt-4">
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded"><%= alert %></div>
      </div>
    <% end %>

    <main class="container mx-auto px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
