<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Scoreboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Scoreboard">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen flex flex-col" data-controller="navbar">
    <nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex items-center justify-between h-14">
          <%= link_to root_path, class: "flex items-center gap-2 font-bold text-gray-900 text-lg" do %>
            <span>&#9824;</span>
            <span>Scoreboard</span>
          <% end %>

          <% if user_signed_in? %>
            <div class="hidden sm:flex items-center gap-4">
              <%= link_to "グループ", groups_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
              <div class="flex items-center gap-3 pl-4 border-l border-gray-200">
                <span class="text-sm text-gray-600"><%= current_user.display_name %></span>
                <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "text-sm text-red-500 hover:text-red-700 cursor-pointer" %>
              </div>
            </div>

            <button type="button" data-action="navbar#toggle" class="sm:hidden p-2 -mr-2 text-gray-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          <% end %>
        </div>

        <% if user_signed_in? %>
          <div data-navbar-target="menu" class="hidden sm:hidden border-t border-gray-100 py-3 space-y-2">
            <%= link_to "グループ", groups_path, class: "block py-2 text-sm text-gray-600 hover:text-gray-900" %>
            <div class="pt-2 border-t border-gray-100 flex items-center justify-between">
              <span class="text-sm text-gray-600"><%= current_user.display_name %></span>
              <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "text-sm text-red-500 hover:text-red-700 cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"><%= alert %></div>
      </div>
    <% end %>

    <main class="flex-1 max-w-5xl mx-auto px-4 py-6 w-full">
      <%= yield %>
    </main>

    <footer class="border-t border-gray-200 bg-white mt-auto">
      <div class="max-w-5xl mx-auto px-4 py-4 text-center text-xs text-gray-400">
        Scoreboard &mdash; ポーカー収支管理
      </div>
    </footer>
  </body>
</html>
