<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">プレイヤー一覧</h1>
  <%= link_to "追加", new_group_player_path(@group), class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
</div>

<% if @players.any? %>
  <div class="bg-white shadow rounded-lg divide-y">
    <% @players.each do |player| %>
      <div class="p-4 flex items-center justify-between">
        <span class="font-medium"><%= player.display_name %></span>
        <% if player.user.present? %>
          <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded">アカウント連携済み</span>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white shadow rounded-lg p-8 text-center text-gray-500">
    <p>まだプレイヤーがいません</p>
  </div>
<% end %>

<div class="mt-4">
  <%= link_to "← #{@group.name}", group_path(@group), class: "text-blue-600 hover:text-blue-800" %>
</div>
