<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">プレイヤー一覧</h1>
  <%= link_to "追加", new_group_player_path(@group), class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 text-sm font-medium transition" %>
</div>

<% if @players.any? %>
  <div class="bg-white shadow-sm rounded-xl border border-gray-100 divide-y divide-gray-50">
    <% @players.each do |player| %>
      <div class="p-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="font-medium text-gray-900"><%= player.display_name %></span>
          <% if player.user.present? %>
            <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full font-medium">アカウント連携済み</span>
          <% end %>
        </div>
        <%= button_to "削除", group_player_path(@group, player), method: :delete,
              data: { turbo_confirm: "「#{player.display_name}」を削除しますか？過去の記録は残ります。" },
              class: "text-sm text-gray-400 hover:text-red-500 transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white shadow-sm rounded-xl p-8 text-center text-gray-400 border border-gray-100">
    <p>まだプレイヤーがいません</p>
  </div>
<% end %>

<div class="mt-4">
  <%= link_to "← #{@group.name}", group_path(@group), class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>
