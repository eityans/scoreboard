<div class="mb-6">
  <h1 class="text-2xl font-bold mb-2"><%= @group.name %></h1>
  <p class="text-sm text-gray-500">メンバー: <%= @group.users.count %>人</p>
</div>

<div class="flex gap-3 mb-6">
  <%= link_to "セッション記録", new_group_poker_session_path(@group), class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
  <%= link_to "プレイヤー管理", group_players_path(@group), class: "bg-gray-200 text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-300" %>
</div>

<div class="bg-white shadow rounded-lg p-4 mb-6">
  <h2 class="text-lg font-semibold mb-3">最近のセッション</h2>
  <% recent_sessions = @group.poker_sessions.order(played_on: :desc).limit(5) %>
  <% if recent_sessions.any? %>
    <div class="divide-y">
      <% recent_sessions.each do |session| %>
        <%= link_to group_poker_session_path(@group, session), class: "block py-3 hover:bg-gray-50 -mx-4 px-4" do %>
          <div class="flex items-center justify-between">
            <span class="font-medium"><%= session.played_on.strftime("%Y/%m/%d") %></span>
            <span class="text-sm text-gray-500"><%= session.session_results.count %>人参加</span>
          </div>
        <% end %>
      <% end %>
    </div>
    <%= link_to "すべてのセッション →", group_poker_sessions_path(@group), class: "block mt-3 text-blue-600 hover:text-blue-800 text-sm" %>
  <% else %>
    <p class="text-gray-500 text-center py-4">まだセッションがありません</p>
  <% end %>
</div>

<div class="bg-white shadow rounded-lg p-4 mb-6">
  <h2 class="text-lg font-semibold mb-2">招待リンク</h2>
  <div class="flex items-center gap-2">
    <input type="text" value="<%= invitation_url(@group.invitation_token) %>" readonly
           class="flex-1 bg-gray-50 border rounded px-3 py-2 text-sm" id="invitation-link">
    <button onclick="navigator.clipboard.writeText(document.getElementById('invitation-link').value).then(() => this.textContent = 'コピー済み!')"
            class="bg-gray-200 hover:bg-gray-300 px-3 py-2 rounded text-sm whitespace-nowrap">コピー</button>
  </div>
</div>

<div class="bg-white shadow rounded-lg p-4 mb-6">
  <h2 class="text-lg font-semibold mb-3">メンバー</h2>
  <ul class="divide-y">
    <% @group.memberships.includes(:user).each do |membership| %>
      <li class="py-2 flex items-center justify-between">
        <span><%= membership.user.display_name %></span>
        <% if membership.role == "owner" %>
          <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded">オーナー</span>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>

<div>
  <%= link_to "← グループ一覧", groups_path, class: "text-blue-600 hover:text-blue-800" %>
</div>
