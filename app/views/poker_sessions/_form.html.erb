<div class="bg-white shadow-sm rounded-xl border border-gray-100 p-6 max-w-lg">
  <%= form_with(model: [@group, poker_session], class: "space-y-4") do |form| %>
    <% if poker_session.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
        <% poker_session.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= form.label :played_on, "日付", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :played_on, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition" %>
    </div>

    <div>
      <%= form.label :note, "メモ", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :note, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition", placeholder: "任意" %>
    </div>

    <div data-controller="nested-form inline-player" data-inline-player-url-value="<%= group_players_path(@group) %>">
      <h3 class="text-sm font-medium text-gray-700 mb-2">参加者と収支</h3>

      <div data-nested-form-target="container" class="space-y-2">
        <% poker_session.session_results.each do |result| %>
          <%= form.fields_for :session_results, result do |result_form| %>
            <%= render "poker_sessions/session_result_fields", form: result_form, players: players %>
          <% end %>
        <% end %>
      </div>

      <template data-nested-form-target="template">
        <%= form.fields_for :session_results, SessionResult.new, child_index: "NEW_RECORD" do |result_form| %>
          <%= render "poker_sessions/session_result_fields", form: result_form, players: players %>
        <% end %>
      </template>

      <div class="flex flex-wrap gap-3 mt-3">
        <button type="button" data-action="nested-form#add"
                class="text-blue-600 hover:text-blue-800 text-sm font-medium transition">
          + 記録を追加
        </button>
        <button type="button" data-action="inline-player#toggle"
                class="text-green-600 hover:text-green-800 text-sm font-medium transition">
          + 新しいプレイヤー
        </button>
      </div>

      <div data-inline-player-target="form" class="hidden mt-3 flex items-center gap-2">
        <input type="text" data-inline-player-target="input" data-action="keydown.enter->inline-player#submit"
               placeholder="プレイヤー名" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition">
        <button type="button" data-action="inline-player#submit"
                class="bg-green-600 text-white px-3 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition cursor-pointer">追加</button>
        <button type="button" data-action="inline-player#toggle"
                class="text-gray-400 hover:text-gray-600 text-sm transition">キャンセル</button>
      </div>
    </div>

    <%= form.submit poker_session.persisted? ? "更新する" : "記録する",
        class: "w-full bg-blue-600 text-white py-2.5 px-4 rounded-lg hover:bg-blue-700 font-medium cursor-pointer transition" %>
  <% end %>
</div>
